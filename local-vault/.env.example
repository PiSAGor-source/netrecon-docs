# =============================================================================
# NetRecon Local Vault — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before deployment.
# NEVER commit the .env file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=vault
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_random_password
POSTGRES_DB=vault

# ---------------------------------------------------------------------------
# Vault Server
# ---------------------------------------------------------------------------

# Port the vault server listens on (HTTPS)
VAULT_PORT=8443

# Master encryption key — used to encrypt all stored secrets.
# Generate with: openssl rand -hex 32
# WARNING: If you lose this key, all stored secrets become unrecoverable.
VAULT_MASTER_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# TLS certificate paths (mounted inside the container at /certs/)
# Place your server.crt and server.key in the vault-certs volume.
# For self-signed certs:
#   openssl req -x509 -newkey rsa:4096 -keyout server.key -out server.crt \
#     -days 365 -nodes -subj "/CN=netrecon-vault"

# Log level: debug, info, warn, error
VAULT_LOG_LEVEL=info

# Maximum database connections in the pool
VAULT_MAX_CONNECTIONS=20

# Token time-to-live in seconds (default: 1 hour)
VAULT_TOKEN_TTL=3600

# Encryption key for backup files — separate from master key.
# Generate with: openssl rand -hex 32
VAULT_BACKUP_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
